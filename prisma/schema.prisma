// ─── POS DEVICES ─────────────────────────────────────────────

model PosDevice {
  id                  String           @id @default(uuid())
  staff_id            String?
  branch_id           String
  tenant_id           String
  serial_number       String           @unique
  model               String           @default("Sunmi V2 Pro")
  status              String           @default("active")
  gateway_type        String?
  gateway_merchant_id String?
  gateway_terminal_id String?
  receipt_header      String?
  print_logo          Boolean          @default(true)
  last_seen           DateTime?
  app_version         String?
  created_at          DateTime         @default(now())
  updated_at          DateTime         @updatedAt
  staff               Staff?           @relation(fields: [staff_id], references: [id])
  branch              Branch           @relation(fields: [branch_id], references: [id])
  tenant              Tenant           @relation(fields: [tenant_id], references: [id])
  transactions        PosTransaction[]

  @@index([branch_id, tenant_id])
  @@map("pos_devices")
}

model PosTransaction {
  id              String     @id @default(uuid())
  device_id       String
  invoice_id      String?
  subscriber_id   String
  staff_id        String
  branch_id       String
  tenant_id       String
  amount          Decimal    @db.Decimal(12, 2)
  payment_method  String
  gateway_tran_id String?
  card_last4      String?
  card_type       String?
  status          String     @default("success")
  receipt_printed Boolean    @default(false)
  receipt_json    Json?
  created_at      DateTime   @default(now())
  device          PosDevice  @relation(fields: [device_id], references: [id])
  subscriber      Subscriber @relation(fields: [subscriber_id], references: [id])
  staff           Staff      @relation(fields: [staff_id], references: [id])

  @@index([device_id, created_at])
  @@index([staff_id, created_at])
  @@index([branch_id, created_at])
  @@map("pos_transactions")
}

// ─── COLLECTOR TRACKING ──────────────────────────────────────

model CollectorDailyReport {
  id                   String    @id @default(uuid())
  staff_id             String
  branch_id            String
  tenant_id            String
  report_date          DateTime  @db.Date
  total_cash           Decimal   @default(0) @db.Decimal(12, 2)
  total_card           Decimal   @default(0) @db.Decimal(12, 2)
  total_electronic     Decimal   @default(0) @db.Decimal(12, 2)
  total_collected      Decimal   @default(0) @db.Decimal(12, 2)
  total_remaining_debt Decimal   @default(0) @db.Decimal(12, 2)
  invoices_count       Int       @default(0)
  subscribers_visited  Int       @default(0)
  whatsapp_sent        Boolean   @default(false)
  whatsapp_sent_at     DateTime?
  sent_to_phone        String?
  report_json          Json?
  created_at           DateTime  @default(now())
  updated_at           DateTime  @updatedAt
  staff                Staff     @relation(fields: [staff_id], references: [id])
  branch               Branch    @relation(fields: [branch_id], references: [id])

  @@unique([staff_id, report_date])
  @@index([branch_id, report_date])
  @@map("collector_daily_reports")
}

model CollectorShift {
  id                   String    @id @default(uuid())
  staff_id             String
  branch_id            String
  tenant_id            String
  shift_date           DateTime  @db.Date
  check_in_at          DateTime?
  check_in_lat         Decimal?  @db.Decimal(10, 8)
  check_in_lng         Decimal?  @db.Decimal(11, 8)
  check_in_selfie      String?
  check_in_valid       Boolean   @default(false)
  check_out_at         DateTime?
  check_out_selfie     String?
  hours_worked         Decimal?  @db.Decimal(5, 2)
  status               String    @default("expected")
  target_subscribers   Int       @default(0)
  visited_subscribers  Int       @default(0)
  collected_cash       Decimal   @default(0) @db.Decimal(12, 2)
  collected_electronic Decimal   @default(0) @db.Decimal(12, 2)
  target_reached       Boolean   @default(false)
  alert_sent           Boolean   @default(false)
  late_minutes         Int       @default(0)
  notes                String?
  created_at           DateTime  @default(now())
  staff                Staff     @relation(fields: [staff_id], references: [id])
  branch               Branch    @relation(fields: [branch_id], references: [id])

  @@unique([staff_id, shift_date])
  @@index([branch_id, shift_date])
  @@map("collector_shifts")
}

model CollectorPermission {
  id                          String   @id @default(uuid())
  staff_id                    String   @unique
  tenant_id                   String
  geofence_radius_m           Int      @default(2000)
  require_shift_checkin       Boolean  @default(false)
  track_gps_interval_min      Int      @default(5)
  daily_target                Int      @default(0)
  alert_if_target_not_reached Boolean  @default(true)
  alert_threshold_pct         Int      @default(70)
  fraud_detection             Boolean  @default(true)
  can_give_discount           Boolean  @default(false)
  discount_max_amount         Decimal  @default(0) @db.Decimal(12, 2)
  discount_timeout_min        Int      @default(15)
  shift_start_time            String?
  shift_end_time              String?
  created_at                  DateTime @default(now())
  updated_at                  DateTime @updatedAt
  staff                       Staff    @relation(fields: [staff_id], references: [id], onDelete: Cascade)

  @@map("collector_permissions")
}

model StaffGpsLog {
  id                String   @id @default(uuid())
  staff_id          String
  branch_id         String
  tenant_id         String
  lat               Decimal  @db.Decimal(10, 8)
  lng               Decimal  @db.Decimal(11, 8)
  accuracy_m        Float?
  source            String   @default("auto")
  payment_id        String?
  is_stop           Boolean  @default(false)
  stop_duration_min Int?
  recorded_at       DateTime @default(now())
  staff             Staff    @relation(fields: [staff_id], references: [id])
  branch            Branch   @relation(fields: [branch_id], references: [id])

  @@index([staff_id, recorded_at])
  @@index([branch_id, recorded_at])
  @@map("staff_gps_logs")
}

// ─── OPERATOR TRACKING ───────────────────────────────────────

model OperatorShift {
  id               String    @id @default(uuid())
  staff_id         String
  generator_id     String
  branch_id        String
  tenant_id        String
  shift_date       DateTime  @db.Date
  check_in_at      DateTime?
  check_in_lat     Decimal?  @db.Decimal(10, 8)
  check_in_lng     Decimal?  @db.Decimal(11, 8)
  check_in_selfie  String?
  check_in_valid   Boolean   @default(false)
  check_out_at     DateTime?
  check_out_lat    Decimal?  @db.Decimal(10, 8)
  check_out_lng    Decimal?  @db.Decimal(11, 8)
  check_out_selfie String?
  hours_worked     Decimal?  @db.Decimal(5, 2)
  status           String    @default("expected")
  notes            String?
  created_at       DateTime  @default(now())
  staff            Staff     @relation(fields: [staff_id], references: [id])
  generator        Generator @relation(fields: [generator_id], references: [id])
  branch           Branch    @relation(fields: [branch_id], references: [id])

  @@unique([staff_id, shift_date])
  @@index([generator_id, shift_date])
  @@map("operator_shifts")
}

model OperatorSchedule {
  id           String    @id @default(uuid())
  staff_id     String
  generator_id String
  branch_id    String
  tenant_id    String
  day_of_week  Int
  shift_start  String
  shift_end    String
  is_active    Boolean   @default(true)
  created_at   DateTime  @default(now())
  staff        Staff     @relation(fields: [staff_id], references: [id])
  generator    Generator @relation(fields: [generator_id], references: [id])

  @@index([generator_id, day_of_week])
  @@map("operator_schedules")
}

model OperatorPermission {
  id                    String   @id @default(uuid())
  staff_id              String   @unique
  tenant_id             String
  can_log_hours         Boolean  @default(true)
  can_add_fuel          Boolean  @default(true)
  can_record_oil_change Boolean  @default(true)
  can_toggle_generator  Boolean  @default(false)
  can_manual_mode       Boolean  @default(false)
  can_view_iot          Boolean  @default(true)
  can_add_expense       Boolean  @default(false)
  require_shift_checkin Boolean  @default(true)
  geofence_radius_m     Int      @default(500)
  shift_start_time      String?
  shift_end_time        String?
  created_at            DateTime @default(now())
  updated_at            DateTime @updatedAt
  staff                 Staff    @relation(fields: [staff_id], references: [id], onDelete: Cascade)

  @@map("operator_permissions")
}

// ─── DISCOUNTS ───────────────────────────────────────────────

model SubscriberDiscount {
  id             String      @id @default(uuid())
  subscriber_id  String?
  branch_id      String
  tenant_id      String
  discount_type  String
  discount_value Decimal     @db.Decimal(10, 2)
  reason         String?
  is_active      Boolean     @default(true)
  valid_from     DateTime    @default(now())
  valid_until    DateTime?
  applied_by     String
  created_at     DateTime    @default(now())
  updated_at     DateTime    @updatedAt
  subscriber     Subscriber? @relation(fields: [subscriber_id], references: [id])
  branch         Branch      @relation(fields: [branch_id], references: [id])

  @@index([branch_id, is_active])
  @@index([subscriber_id, is_active])
  @@map("subscriber_discounts")
}

model TenantDiscount {
  id             String    @id @default(uuid())
  tenant_id      String
  discount_type  String
  discount_value Decimal   @db.Decimal(10, 2)
  promo_code     String?
  reason         String?
  is_active      Boolean   @default(true)
  valid_from     DateTime  @default(now())
  valid_until    DateTime?
  applied_by     String
  auto_renew     Boolean   @default(false)
  created_at     DateTime  @default(now())
  updated_at     DateTime  @updatedAt
  tenant         Tenant    @relation(fields: [tenant_id], references: [id])

  @@index([tenant_id, is_active])
  @@index([promo_code])
  @@map("tenant_discounts")
}

model CollectorDiscountRequest {
  id             String     @id @default(uuid())
  staff_id       String
  subscriber_id  String
  invoice_id     String?
  branch_id      String
  tenant_id      String
  amount         Decimal    @db.Decimal(12, 2)
  reason         String?
  status         String     @default("pending")
  decided_by     String?
  decided_at     DateTime?
  decision_note  String?
  expires_at     DateTime
  notified_owner Boolean    @default(false)
  discount_id    String?
  created_at     DateTime   @default(now())
  staff          Staff      @relation(fields: [staff_id], references: [id])
  subscriber     Subscriber @relation(fields: [subscriber_id], references: [id])
  branch         Branch     @relation(fields: [branch_id], references: [id])

  @@index([branch_id, status])
  @@index([staff_id, created_at])
  @@map("collector_discount_requests")
}

// ─── AI REPORTS ──────────────────────────────────────────────

model AiReport {
  id           String   @id @default(uuid())
  branch_id    String
  tenant_id    String
  month        Int
  year         Int
  content_ar   String
  prompt_used  String?
  tokens_used  Int?
  generated_at DateTime @default(now())
  branch       Branch   @relation(fields: [branch_id], references: [id])

  @@unique([branch_id, month, year])
  @@index([tenant_id, year])
  @@map("ai_reports")
}

model OilPressureLog {
  id           String   @id @default(uuid())
  engine_id    String
  branch_id    String
  pressure_bar Decimal  @db.Decimal(5, 2)
  source       String   @default("manual")
  notes        String?
  logged_at    DateTime @default(now())

  @@index([engine_id, logged_at])
  @@map("oil_pressure_logs")
}

model LoadLog {
  id               String   @id @default(uuid())
  engine_id        String
  branch_id        String
  load_ampere      Decimal  @db.Decimal(8, 2)
  gold_current_a   Decimal? @db.Decimal(8, 2)
  normal_current_a Decimal? @db.Decimal(8, 2)
  source           String   @default("manual")
  logged_at        DateTime @default(now())

  @@index([engine_id, logged_at])
  @@map("load_logs")
}

model StaffSalaryConfig {
  id             String   @id @default(uuid())
  staff_id       String   @unique
  tenant_id      String
  branch_id      String
  monthly_amount Decimal  @default(0) @db.Decimal(12, 2)
  notes          String?
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt
  staff          Staff    @relation(fields: [staff_id], references: [id], onDelete: Cascade)
  tenant         Tenant   @relation(fields: [tenant_id], references: [id])

  @@map("staff_salary_configs")
}

model SalaryPayment {
  id                 String   @id @default(uuid())
  staff_id           String
  tenant_id          String
  branch_id          String
  month              Int
  year               Int
  amount             Decimal  @db.Decimal(12, 2)
  payment_type       String   @default("salary") // "salary" | "tip"
  paid_from_delivery Boolean  @default(false)
  delivery_id        String?
  notes              String?
  tip_notes          String?
  paid_at            DateTime @default(now())
  created_at         DateTime @default(now())
  staff              Staff    @relation(fields: [staff_id], references: [id])
  tenant             Tenant   @relation(fields: [tenant_id], references: [id])

  @@map("salary_payments")
}

model AppVersion {
  id             String   @id @default(uuid())
  app_key        String   @unique // "staff" | "iot" | "partner"
  min_version    String
  latest_version String
  update_url     String?
  changelog_ar   String?
  changelog_en   String?
  force          Boolean  @default(false)
  released_at    DateTime @default(now())
  updated_at     DateTime @updatedAt

  @@map("app_versions")
}

// Logged when a collector records a non-payment visit (subscriber not
// home, locked, refused, etc.). Read by the route-history sort + future
// "visits log" report.
model VisitLog {
  id            String   @id @default(uuid())
  tenant_id     String
  branch_id     String
  subscriber_id String
  staff_id      String?
  reason        String // "not home" / "refused" / "locked" / "other"
  notes         String?
  lat           Float?
  lng           Float?
  created_at    DateTime @default(now())

  @@index([tenant_id, created_at])
  @@index([subscriber_id, created_at])
  @@map("visit_logs")
}

// Field complaint reported by a collector (meter issue, voltage drop,
// outage on a subscriber's line, etc.). Read by manager-app's
// complaints/issues feed (future) and surfaced as a notification.
model SubscriberComplaint {
  id            String    @id @default(uuid())
  tenant_id     String
  branch_id     String
  subscriber_id String
  staff_id      String?
  type          String // outage / weak_voltage / wrong_meter / technical / other
  notes         String?
  status        String    @default("open") // open | resolved | dismissed
  created_at    DateTime  @default(now())
  resolved_at   DateTime?

  @@index([tenant_id, status, created_at])
  @@index([subscriber_id, created_at])
  @@map("subscriber_complaints")
}

// Tenant-wide announcements used by multiple routes via raw SQL.
// Declaring the model here so the schema is self-documenting and
// so `prisma db push` can create the table on fresh deploys.
model Announcement {
  id             String   @id @default(uuid())
  tenant_id      String
  type           String   @default("general")
  message        String
  target         String   @default("all") // all | gold | normal | collectors | operators | accountants | specific
  is_urgent      Boolean  @default(false)
  auto_generated Boolean  @default(false)
  // When set, this announcement is a direct message to a single
  // subscriber (target will be 'specific'). Null for broadcasts.
  subscriber_id  String?
  created_by     String?
  created_at     DateTime @default(now())

  @@index([tenant_id, created_at])
  @@index([subscriber_id])
  @@map("announcements")
}

// Tracks which subscribers have read which announcements, so the
// subscriber app's bell can show an accurate unread count.
model SubscriberAnnouncementRead {
  subscriber_id   String
  announcement_id String
  read_at         DateTime @default(now())

  @@id([subscriber_id, announcement_id])
  @@map("subscriber_reads")
}

// Per-tenant plan overrides — limits + feature flags that override
// the defaults in src/app/api/plan/route.ts.
model TenantPlan {
  tenant_id         String    @id
  plan_name         String
  max_subscribers   Int
  max_staff         Int
  max_branches      Int
  online_payment    Boolean   @default(false)
  financial_reports Boolean   @default(false)
  custom_app        Boolean   @default(false)
  announcements     Boolean   @default(false)
  advanced_reports  Boolean   @default(false)
  api_access        Boolean   @default(false)
  white_label       Boolean   @default(false)
  expires_at        DateTime?
  is_active         Boolean   @default(true)
  created_at        DateTime  @default(now())
  updated_at        DateTime  @default(now())

  @@map("tenant_plans")
}

// ═══════════════════════════════════════════════════════════════
// SAAS SUBSCRIPTION BILLING — sync with company-admin/prisma/schema.prisma
// Online payment of Amper subscription itself (Tenant → Amper).
// Added 2026-04-29.
// ═══════════════════════════════════════════════════════════════

model Plan {
  id                   String   @id
  name_en              String
  name_ar              String
  price_monthly        Int
  price_3m             Int
  price_6m             Int
  price_12m            Int
  generator_limit      Int
  subscriber_limit     Int
  staff_limit          Int      @default(-1)
  has_iot              Boolean  @default(false)
  has_ai               Boolean  @default(false)
  has_subscriber_app   Boolean  @default(false)
  has_api              Boolean  @default(false)
  has_multi_branch     Boolean  @default(false)
  has_priority_support Boolean  @default(false)
  is_active            Boolean  @default(true)
  is_popular           Boolean  @default(false)
  sort_order           Int      @default(0)
  tagline_ar           String?
  tagline_en           String?
  created_at           DateTime @default(now())
  updated_at           DateTime @updatedAt

  @@map("plans")
}

model TenantPaymentMethod {
  id              String              @id @default(uuid())
  tenant_id       String
  gateway         PaymentGateway
  gateway_token   String
  gateway_ref     String?
  display_name    String?
  last_four       String?
  is_default      Boolean             @default(false)
  is_active       Boolean             @default(true)
  last_charged_at DateTime?
  last_failure_at DateTime?
  failure_count   Int                 @default(0)
  expires_at      DateTime?
  created_at      DateTime            @default(now())
  updated_at      DateTime            @updatedAt
  tenant          Tenant              @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  saas_payments   SaasOnlinePayment[]

  @@index([tenant_id, is_active])
  @@map("tenant_payment_methods")
}

model SaasOnlinePayment {
  id                String               @id @default(uuid())
  tenant_id         String
  invoice_id        String?
  payment_method_id String?
  gateway           PaymentGateway
  gateway_txn_id    String?
  gateway_ref       String?
  amount            Decimal              @db.Decimal(12, 2)
  currency          String               @default("IQD")
  status            SaasPaymentStatus    @default(initiated)
  failure_reason    String?
  is_auto_renewal   Boolean              @default(false)
  webhook_payload   Json?
  redirect_url      String?
  initiated_at      DateTime             @default(now())
  completed_at      DateTime?
  tenant            Tenant               @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  invoice           BillingInvoice?      @relation(fields: [invoice_id], references: [id])
  payment_method    TenantPaymentMethod? @relation(fields: [payment_method_id], references: [id])

  @@index([tenant_id, status])
  @@index([gateway_txn_id])
  @@map("saas_online_payments")
}

enum CouponType {
  percent
  fixed
}

model SaasCoupon {
  id               String     @id @default(uuid())
  code             String     @unique
  description      String?
  type             CouponType
  amount           Int
  applicable_plans String[]   @default([])
  min_amount       Int        @default(0)
  max_redemptions  Int        @default(0)
  redeemed_count   Int        @default(0)
  expires_at       DateTime?
  is_active        Boolean    @default(true)
  created_by       String?
  created_at       DateTime   @default(now())
  updated_at       DateTime   @updatedAt
  redemptions      SaasCouponRedemption[]
  @@map("saas_coupons")
}

model SaasCouponRedemption {
  id              String     @id @default(uuid())
  coupon_id       String
  tenant_id       String
  invoice_id      String?
  discount_amount Int
  redeemed_at     DateTime   @default(now())
  coupon          SaasCoupon @relation(fields: [coupon_id], references: [id], onDelete: Cascade)
  @@index([tenant_id, redeemed_at])
  @@map("saas_coupon_redemptions")
}

model AmperGatewayCredentials {
  id                    String         @id @default(uuid())
  gateway               PaymentGateway @unique
  encrypted_credentials String
  is_test_mode          Boolean        @default(true)
  is_enabled            Boolean        @default(true)
  display_name          String?
  last_validated_at     DateTime?
  last_validation_error String?
  updated_by            String?
  created_at            DateTime       @default(now())
  updated_at            DateTime       @updatedAt
  @@map("amper_gateway_credentials")
}

model SubscriptionEvent {
  id         String                @id @default(uuid())
  tenant_id  String
  event_type SubscriptionEventType
  metadata   Json?
  created_at DateTime              @default(now())
  tenant     Tenant                @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@index([tenant_id, created_at])
  @@index([event_type, created_at])
  @@map("subscription_events")
}
