model Expense {
  id           String            @id @default(uuid())
  branch_id    String
  staff_id     String?
  category     String
  amount       Decimal           @db.Decimal(12, 2)
  description  String?
  receipt_url  String?
  // Payment type — drives the supplier-debt machinery.
  //   'cash'    → fully paid at the time the expense was recorded
  //   'credit'  → fully unpaid; entire amount is a debt to supplier
  //   'partial' → some paid, some still owed
  payment_type String            @default("cash")
  amount_paid  Decimal           @default(0) @db.Decimal(12, 2)
  amount_owed  Decimal           @default(0) @db.Decimal(12, 2)
  // Optional link to a supplier when the expense is on credit.
  supplier_id  String?
  // Optional link to the originating fuel_log or maintenance_log id
  // ("fuel_log:xxx" or "oil_change:yyy") so we can show in the
  // expense detail "this debt came from refilling 200L on date X".
  related_to   String?
  created_at   DateTime          @default(now())
  updated_at   DateTime          @default(now()) @updatedAt
  branch       Branch            @relation(fields: [branch_id], references: [id])
  supplier     Supplier?         @relation(fields: [supplier_id], references: [id], onDelete: SetNull)
  payments     SupplierPayment[]

  @@index([branch_id, created_at])
  @@index([supplier_id])
  @@map("expenses")
}

// ─── SUPPLIERS / CREDITORS ───────────────────────────────────
//
// A supplier is anyone the generator buys from on credit — fuel
// dealer, oil dealer, spare-parts shop, mechanic. The system tracks
// what the generator owes each supplier (sum of unpaid expenses
// minus payments) and exposes that information to both the manager
// and (read-only) the partner portal so partners can see the real
// debt position before computing their share of the profit.

model Supplier {
  id            String            @id @default(uuid())
  tenant_id     String
  name          String
  phone         String?
  // Type — used to route auto-created debts from fuel/oil purchases
  //   'fuel'         → fuel station / dealer
  //   'oil'          → oil dealer
  //   'spare_parts'  → mechanical / electrical parts
  //   'service'      → labour / repair shop
  //   'other'        → catch-all
  supplier_type String            @default("other")
  notes         String?
  is_active     Boolean           @default(true)
  created_at    DateTime          @default(now())
  updated_at    DateTime          @updatedAt
  expenses      Expense[]
  payments      SupplierPayment[]

  @@index([tenant_id, is_active])
  @@map("suppliers")
}

model SupplierPayment {
  id             String   @id @default(uuid())
  tenant_id      String
  supplier_id    String
  // Optional link to the specific expense being settled. NULL means
  // the payment is a generic credit against the supplier's running
  // balance (used when the user just hands over a sum without
  // assigning it to a particular invoice).
  expense_id     String?
  amount         Decimal  @db.Decimal(12, 2)
  payment_method String   @default("cash")
  notes          String?
  recorded_by    String?
  paid_at        DateTime @default(now())
  supplier       Supplier @relation(fields: [supplier_id], references: [id], onDelete: Cascade)
  expense        Expense? @relation(fields: [expense_id], references: [id], onDelete: SetNull)

  @@index([supplier_id, paid_at])
  @@index([tenant_id, paid_at])
  @@map("supplier_payments")
}

