// Fuel tanks — each generator can have multiple tanks (internal day
// tank, external storage barrel, per-engine tanks). The IoT gateway
// sends fuel_tanks[] array with readings for each connected sensor.
model FuelTank {
  id              String    @id @default(uuid())
  generator_id    String
  generator       Generator @relation(fields: [generator_id], references: [id])
  name            String // "داخلي" / "خارجي" / "محرك 1"
  tank_type       String    @default("internal") // internal | external | engine
  sensor_index    Int       @default(0) // matches the GPIO index on the ESP32
  capacity_liters Float? // total capacity (optional, for liters calc)
  height_cm       Float     @default(100) // sensor-to-bottom distance
  empty_cm        Float     @default(100) // distance reading when empty
  full_cm         Float     @default(5) // distance reading when full
  current_pct     Float     @default(0) // last known fuel level %
  last_updated    DateTime?
  is_active       Boolean   @default(true)
  created_at      DateTime  @default(now())
