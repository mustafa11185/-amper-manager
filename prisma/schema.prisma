// ─── PARTNERSHIPS ─────────────────────────────────────────────

model Partner {
  id            String                @id @default(uuid())
  tenant_id     String
  name          String
  phone         String?
  national_id   String?
  notes         String?
  is_active     Boolean               @default(true)
  // Optional: read-only login for partner (Business+ plan)
  access_code   String?               @unique // 6-digit code
  // What this specific partner is allowed to see in the portal.
  // Owner controls this from partner_detail_screen. Default = empty {}.
  // Keys mirror the toggles in the Flutter permissions sheet:
  //   view_partners_list, view_partners_balances, view_revenue,
  //   view_expenses, view_subscribers_count (default true),
  //   view_iot_status, request_withdrawal, view_reports.
  permissions   Json                  @default("{}")
  joined_at     DateTime              @default(now())
  created_at    DateTime              @default(now())
  updated_at    DateTime              @default(now()) @updatedAt
  shares        PartnerShare[]
  contributions PartnerContribution[]
  withdrawals   PartnerWithdrawal[]
  sessions      PartnerSession[]

  @@index([tenant_id, is_active])
  @@map("partners")
}

// DB-backed partner login sessions. Replaces the in-memory token Map
// (which got wiped on every Render restart and logged everyone out).
model PartnerSession {
