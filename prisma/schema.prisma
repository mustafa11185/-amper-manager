  fuel_pct_end    Float
  liters_consumed Float // Estimated using tank_capacity
  cost_iqd        Decimal? @db.Decimal(12, 2)
  // Engine load during window
  avg_current_a   Float?
  runtime_minutes Int // How many minutes engine was running in this window
  liters_per_hour Float?

  @@index([generator_id, window_end])
  @@index([tenant_id, window_end])
  @@map("fuel_consumption")
}

model VoltageEvent {
  id           String    @id @default(uuid())
  tenant_id    String
  branch_id    String
  generator_id String
  device_id    String?
  type         String // "low_warning" | "low_critical" | "high_warning" | "high_critical"
